// GCS — General Computing Solutions
// Prisma Schema — SQLite (local dev) → switch to PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// MODELS
// ============================================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  role              String    @default("CLIENT_USER") // ADMIN | STAFF | CLIENT_ADMIN | CLIENT_USER
  avatar            String?
  passwordHash      String?
  phone             String?
  jobTitle          String?
  is2FAEnabled      Boolean   @default(false)
  twoFASecret       String?
  emailVerified     DateTime?
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  notificationPrefs String?   // JSON: { project_updates, ticket_replies, invoice_notifications, chat_messages, system_announcements }
  aiPinHash         String?   // bcrypt hash of admin AI PIN
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts              Account[]
  sessions              Session[]
  ownedProjects         Project[]       @relation("ProjectOwner")
  assignedTasks         Task[]          @relation("TaskAssignee")
  ticketMessages        TicketMessage[]
  messages              Message[]
  notifications         Notification[]
  uploadedFiles         File[]
  activityLogs          ActivityLog[]   @relation("ActivityActor")
  submittedRequirements Requirement[]
  assignedTickets       Ticket[]        @relation("TicketAssignee")
  pitches               Pitch[]
  leadSearches          LeadSearch[]
  aiConversations       AiConversation[]
  resolvedAlerts        GuardAlert[]    @relation("AlertResolver")
  assignedIncidents     GuardIncident[] @relation("IncidentAssignee")
  createdCommands       GuardCommand[]  @relation("CommandCreator")
  approvedPatches       GuardPatchHistory[]      @relation("PatchApprover")
  configTemplates       GuardConfigTemplate[]    @relation("ConfigTemplateCreator")
  configDeployments     GuardConfigDeployment[]  @relation("ConfigDeployer")
  vaultEntries          VaultEntry[]             @relation("VaultEntryCreator")
  vaultAccessLogs       VaultAccessLog[]         @relation("VaultAccessLogs")

  @@index([email])
  @@index([organizationId])
}

model Organization {
  id               String    @id @default(cuid())
  name             String
  domain           String?   @unique
  logo             String?
  website          String?
  phone            String?
  email            String?
  address          String?
  city             String?
  state            String?
  zipCode          String?
  country          String?   @default("US")
  industry         String?
  description      String?
  subscriptionTier String    @default("NONE") // NONE | GCSGUARD_MANAGED_FREE | GCSGUARD_MANAGED | GCSGUARD_NON_MANAGED
  isActive         Boolean   @default(true)
  googleRating     Float?
  yelpUrl          String?
  bbbUrl           String?
  socialLinks      String?   // JSON: {facebook, linkedin, instagram, ...}
  notes            String?
  trialEndsAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  users       User[]
  projects    Project[]
  tickets     Ticket[]
  invoices    Invoice[]
  guardAgents GuardAgent[]

  @@index([domain])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("PLANNING") // PLANNING | ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  progress    Int       @default(0)
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  ownerId        String
  owner          User         @relation("ProjectOwner", fields: [ownerId], references: [id])

  milestones   Milestone[]
  tasks        Task[]
  requirements Requirement[]
  messages     Message[]
  files        File[]
  activityLogs ActivityLog[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | OVERDUE
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO | IN_PROGRESS | REVIEW | DONE | CANCELLED
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  dueDate     DateTime?
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?
  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([milestoneId])
  @@index([assigneeId])
  @@index([status])
}

model Requirement {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("OPEN") // OPEN | APPROVED | IN_PROGRESS | DONE | REJECTED
  priority    String    @default("MEDIUM")
  type        String    @default("FEATURE") // FEATURE | BUG | IMPROVEMENT | TASK
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy String
  submitter   User    @relation(fields: [submittedBy], references: [id])

  @@index([projectId])
  @@index([submittedBy])
}

model Ticket {
  id           String    @id @default(cuid())
  ticketNumber String    @unique
  subject      String
  description  String
  status       String    @default("OPEN") // OPEN | IN_PROGRESS | WAITING | RESOLVED | CLOSED
  priority     String    @default("MEDIUM")
  category     String    @default("GENERAL") // GENERAL | BILLING | TECHNICAL | FEATURE | OTHER
  slaDeadline  DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  assignedTo     String?
  assignee       User?        @relation("TicketAssignee", fields: [assignedTo], references: [id])

  messages TicketMessage[]
  files    File[]

  @@index([organizationId])
  @@index([assignedTo])
  @@index([status])
  @@index([ticketNumber])
}

model TicketMessage {
  id         String    @id @default(cuid())
  content    String
  isInternal Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
}

model Message {
  id        String    @id @default(cuid())
  content   String
  type      String    @default("TEXT") // TEXT | FILE | SYSTEM
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    Message?  @relation("MessageReplies", fields: [parentId], references: [id])
  replies   Message[] @relation("MessageReplies")

  @@index([projectId])
  @@index([authorId])
  @@index([parentId])
}

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  content   String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model File {
  id        String    @id @default(cuid())
  name      String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  ticketId   String?
  ticket     Ticket?  @relation(fields: [ticketId], references: [id])
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id])

  @@index([projectId])
  @@index([ticketId])
  @@index([uploadedBy])
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  amount        Float
  tax           Float     @default(0)
  currency      String    @default("USD")
  status        String    @default("DRAFT") // DRAFT | SENT | PAID | OVERDUE | CANCELLED
  dueDate       DateTime?
  paidAt        DateTime?
  pdfUrl                String?
  notes                 String?
  lineItems             String?   // JSON serialized
  stripeSessionId       String?
  stripePaymentIntentId String?
  createdAt             DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([invoiceNumber])
}

model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  metadata   String?  // JSON serialized
  createdAt  DateTime @default(now())

  actorId   String
  actor     User     @relation("ActivityActor", fields: [actorId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([projectId])
}

// ============================================================
// NEXT AUTH
// ============================================================

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model LeadSearch {
  id           String   @id @default(cuid())
  query        String
  location     String
  resultsCount Int      @default(0)
  results      String?  // JSON array of LeadResult
  createdAt    DateTime @default(now())

  searchedById String
  searchedBy   User   @relation(fields: [searchedById], references: [id])

  @@index([searchedById])
  @@index([createdAt])
}

model Pitch {
  id            String   @id @default(cuid())
  businessName  String
  websiteUrl    String
  pitchText     String
  securityScore Int      @default(0)   // headers passed / total * 100
  presenceScore Int      @default(0)   // digital presence quality 0-100
  dealScore     Int      @default(0)   // overall deal potential 0-100
  painCount     Int      @default(0)   // number of pain points identified
  pentestData       String?   // JSON-serialized PentestResults from runPentest()
  businessIntelData String?   // JSON-serialized BusinessIntelResults from runBusinessIntel()
  reportData        String?   // JSON-serialized full SecurityReport (findings, categories, remediation)
  emailsSent        String?   // JSON array of { email, sentAt } records
  brandColor        String?   // Hex color from client website (e.g. "#1565C0")
  brandLogoUrl      String?   // URL to client logo (og:image, apple-touch-icon, favicon)
  contactEmail      String?   // Contact email found on client website
  facebookPageUrl   String?   // Facebook page URL discovered for no-website businesses
  createdAt         DateTime @default(now())

  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([createdAt])
}

// ============================================================
// GCSGUARD AI — Conversations & Messages
// ============================================================

model AiConversation {
  id        String   @id @default(cuid())
  title     String   @default("New conversation")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AiMessage[]

  @@index([userId])
  @@index([updatedAt])
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // "user" | "assistant"
  content        String
  toolCalls      String?        // JSON string of tool executions
  contentBlocks  String?        // JSON string of content block ordering (text + tool interleaving)
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

// ============================================================
// GCSGUARD — Managed Security Monitoring
// ============================================================

model GuardAgent {
  id            String    @id @default(cuid())
  name          String
  apiKey        String    @unique
  apiKeyPrefix  String
  hostname      String?
  ipAddress     String?
  os            String?
  kernelVersion String?
  distro        String?   // "ubuntu", "debian", "centos", "rhel"
  distroVersion String?   // "22.04", "11", "9"
  packageManager String?  // "apt", "yum", "dnf"
  status        String    @default("PENDING") // PENDING | ONLINE | OFFLINE | DEGRADED
  lastHeartbeat DateTime?
  lastInventorySync DateTime?
  lastPatchCheck    DateTime?
  pendingUpdates    Int       @default(0)
  securityUpdates   Int       @default(0)
  config        String? // JSON: monitoring intervals, thresholds

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  metrics           GuardMetric[]
  alerts            GuardAlert[]
  commands          GuardCommand[]
  scans             GuardScan[]
  devices           GuardDevice[]
  packages          GuardPackage[]
  patchHistory      GuardPatchHistory[]
  configDeployments GuardConfigDeployment[]
  urlMonitors       GuardUrlMonitor[]
  serviceStatuses   GuardServiceStatus[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model GuardAlert {
  id               String    @id @default(cuid())
  type             String // BRUTE_FORCE | FILE_CHANGE | SUSPICIOUS_PROCESS | PORT_SCAN | MALWARE | CONFIG_CHANGE | RESOURCE_SPIKE
  severity         String // CRITICAL | HIGH | MEDIUM | LOW | INFO
  title            String
  description      String
  evidence         String? // JSON: raw log lines, metrics, file diffs
  status           String    @default("OPEN") // OPEN | INVESTIGATING | RESOLVED | FALSE_POSITIVE
  aiAnalysis       String?
  aiRecommendation String?
  resolvedAt       DateTime?

  resolvedById String?
  resolvedBy   User?          @relation("AlertResolver", fields: [resolvedById], references: [id])
  agentId      String
  agent        GuardAgent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  incidentId   String?
  incident     GuardIncident? @relation(fields: [incidentId], references: [id])

  createdAt DateTime @default(now())

  @@index([agentId, status])
  @@index([severity])
  @@index([createdAt])
}

model GuardIncident {
  id          String    @id @default(cuid())
  title       String
  severity    String
  status      String    @default("OPEN") // OPEN | INVESTIGATING | CONTAINED | RESOLVED
  description String?
  aiSummary   String?

  alerts       GuardAlert[]
  assignedToId String?
  assignedTo   User?    @relation("IncidentAssignee", fields: [assignedToId], references: [id])

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model GuardCommand {
  id      String  @id @default(cuid())
  type    String // BLOCK_IP | UNBLOCK_IP | RESTART_SERVICE | RUN_SCAN | KILL_PROCESS | CUSTOM
  payload String // JSON: command parameters
  status  String  @default("PENDING") // PENDING | SENT | EXECUTING | COMPLETED | FAILED
  result  String? // JSON: execution output

  agentId     String
  agent       GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User       @relation("CommandCreator", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now())
  sentAt      DateTime?
  completedAt DateTime?

  @@index([agentId, status])
}

model GuardMetric {
  id       String  @id @default(cuid())
  type     String // CPU | MEMORY | DISK | LOAD | NETWORK_IN | NETWORK_OUT
  value    Float
  metadata String? // JSON: per-core CPU, per-disk usage, etc.

  agentId String
  agent   GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  timestamp DateTime @default(now())

  @@index([agentId, type, timestamp])
}

model GuardScan {
  id           String    @id @default(cuid())
  type         String // FULL | QUICK | VULNERABILITY | FILE_INTEGRITY
  status       String    @default("RUNNING") // RUNNING | COMPLETED | FAILED
  results      String? // JSON: full scan results
  findingCount Int       @default(0)
  completedAt  DateTime?

  agentId String
  agent   GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  startedAt DateTime @default(now())

  @@index([agentId])
}

model GuardDevice {
  id          String  @id @default(cuid())
  macAddress  String
  ipAddress   String?
  hostname    String?
  vendor      String? // OUI lookup: Cisco, HP, Yealink, Ubiquiti, etc.
  deviceType  String  @default("UNKNOWN") // WORKSTATION | SERVER | PRINTER | IP_PHONE | WIFI_AP | ROUTER | SWITCH | IOT | CAMERA | UNKNOWN
  os          String? // Detected OS fingerprint
  isAuthorized Boolean @default(false) // Admin-approved device
  isOnline    Boolean @default(true)
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  metadata    String? // JSON: open ports, services, SNMP data

  agentId String
  agent   GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, macAddress])
  @@index([agentId, deviceType])
  @@index([isAuthorized])
}

// ============================================================
// GCSGUARD — Patch Management, Config Management, Monitoring
// ============================================================

model GuardPackage {
  id               String   @id @default(cuid())
  name             String
  version          String
  newVersion       String?
  source           String   @default("apt") // apt | yum | dnf | npm | pip
  isSecurityUpdate Boolean  @default(false)
  status           String   @default("INSTALLED") // INSTALLED | UPDATE_AVAILABLE | UPDATING | UPDATED
  agentId          String
  agent            GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lastChecked      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([agentId, name, source])
  @@index([agentId, status])
  @@index([isSecurityUpdate])
}

model GuardPatchHistory {
  id           String    @id @default(cuid())
  packageName  String
  fromVersion  String
  toVersion    String
  source       String    @default("apt")
  status       String    @default("PENDING") // PENDING | APPROVED | INSTALLING | COMPLETED | FAILED | ROLLED_BACK
  output       String?
  error        String?
  agentId      String
  agent        GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  approvedById String?
  approvedBy   User?     @relation("PatchApprover", fields: [approvedById], references: [id])
  createdAt    DateTime  @default(now())
  approvedAt   DateTime?
  completedAt  DateTime?

  @@index([agentId, status])
  @@index([createdAt])
}

model GuardConfigTemplate {
  id             String   @id @default(cuid())
  name           String
  filePath       String
  content        String
  description    String?
  restartService String?
  version        Int      @default(1)
  createdById    String
  createdBy      User     @relation("ConfigTemplateCreator", fields: [createdById], references: [id])
  deployments    GuardConfigDeployment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([filePath])
}

model GuardConfigDeployment {
  id              String    @id @default(cuid())
  filePath        String
  status          String    @default("PENDING") // PENDING | DEPLOYING | COMPLETED | FAILED | ROLLED_BACK
  previousContent String?
  newContent      String
  diff            String?
  output          String?
  error           String?
  templateId      String?
  template        GuardConfigTemplate? @relation(fields: [templateId], references: [id])
  agentId         String
  agent           GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  deployedById    String
  deployedBy      User     @relation("ConfigDeployer", fields: [deployedById], references: [id])
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([agentId, status])
  @@index([templateId])
}

model GuardUrlMonitor {
  id             String   @id @default(cuid())
  url            String
  name           String
  method         String   @default("GET")
  expectedStatus Int      @default(200)
  timeoutMs      Int      @default(10000)
  intervalSec    Int      @default(60)
  isActive       Boolean  @default(true)
  agentId        String
  agent          GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lastStatus     Int?
  lastResponseMs Int?
  lastChecked    DateTime?
  lastError      String?
  isDown         Boolean  @default(false)
  downSince      DateTime?
  checks         GuardUrlCheck[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agentId, isActive])
}

model GuardUrlCheck {
  id         String   @id @default(cuid())
  statusCode Int?
  responseMs Int?
  error      String?
  isUp       Boolean
  monitorId  String
  monitor    GuardUrlMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  checkedAt  DateTime @default(now())

  @@index([monitorId, checkedAt])
}

model GuardServiceStatus {
  id          String   @id @default(cuid())
  serviceName String
  isActive    Boolean  @default(true)
  isEnabled   Boolean  @default(true)
  subState    String?
  memoryUsage Int?
  cpuUsage    Float?
  uptime      Int?
  agentId     String
  agent       GuardAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lastChecked DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([agentId, serviceName])
  @@index([agentId])
}

// ─── Encrypted Credential Vault ──────────────────────────────────────────────

model VaultEntry {
  id          String    @id @default(cuid())
  label       String
  category    String    @default("OTHER") // CLOUD|HOSTING|EMAIL|DOMAIN|DATABASE|API|SOCIAL|PAYMENT|VPN|OTHER
  url         String?
  description String?
  encUsername String? // AES-256-GCM encrypted
  encPassword String? // AES-256-GCM encrypted
  encApiKey   String? // AES-256-GCM encrypted
  encNotes    String? // AES-256-GCM encrypted
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdById String
  createdBy   User @relation("VaultEntryCreator", fields: [createdById], references: [id])

  accessLogs VaultAccessLog[]

  @@index([category])
  @@index([createdById])
}

model VaultAccessLog {
  id        String      @id @default(cuid())
  action    String // CREATE|UPDATE|DELETE|REVEAL|AI_REVEAL
  metadata  String? // JSON
  createdAt DateTime    @default(now())

  entryId String?
  entry   VaultEntry? @relation(fields: [entryId], references: [id])
  userId  String
  user    User @relation("VaultAccessLogs", fields: [userId], references: [id])

  @@index([entryId])
  @@index([userId])
  @@index([createdAt])
}
